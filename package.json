  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/AbraJF/AbraJF.github.io/issues"
  },
  "homepage": "https://github.com/AbraJF/AbraJF.github.io#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "puppeteer": "^25.1.0"
  }
}
